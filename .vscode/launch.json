{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Tiinex AI Provenance VS Code Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/ides/vscode"
			],
			"outFiles": [
				"${workspaceFolder}/ides/vscode/dist/**/*.js"
			],
			"preLaunchTask": "watch ai provenance vscode extension"
		}
	]
}